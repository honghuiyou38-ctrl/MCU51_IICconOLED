  28          /**********************************************
  29          // IIC Write Command
  30          **********************************************/
  31          void Write_IIC_Command(unsigned char IIC_Command)
  32          {
  33   1        IIC_Start();
  34   1        IIC_Send_byte(0x78);      //Slave address,SA0=0
  35   1        IIC_Recv_ACK(); 
  36   1        IIC_Send_byte(0x00);      //write command
  37   1        IIC_Recv_ACK(); 
  38   1        IIC_Send_byte(IIC_Command); 
  39   1        IIC_Recv_ACK(); 
  40   1        IIC_Stop();
  41   1      }
  42          /**********************************************
  43          // IIC Write Data
  44          **********************************************/
  45          void Write_IIC_Data(unsigned char IIC_Data)
  46          {
  47   1        IIC_Start();
  48   1        IIC_Send_byte(0x78);      //D/C#=0; R/W#=0
  49   1        IIC_Recv_ACK(); 
  50   1        IIC_Send_byte(0x40);      //write data
  51   1        IIC_Recv_ACK(); 
  52   1        IIC_Send_byte(IIC_Data);
  53   1        IIC_Recv_ACK(); 
  54   1        IIC_Stop();
