  57          void OLED_WR_Byte(unsigned dat,unsigned cmd)
  58          {
  59   1        if(cmd)
  60   1        {
  61   2          Write_IIC_Data(dat);  
  62   2        }
  63   1        else
  64   1        {
  65   2          Write_IIC_Command(dat);   
  66   2        }
  67   1      }
