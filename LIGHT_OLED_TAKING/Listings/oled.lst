  69          /********************************************
  70          // fill_Picture
  71          ********************************************/
  72          void fill_picture(unsigned char fill_Data)
  73          {
  74   1        unsigned char m,n;
  75   1        for(m=0;m<8;m++)
  76   1        {
  77   2          OLED_WR_Byte(0xb0+m,0);   //page0-page1
  78   2          OLED_WR_Byte(0x00,0);   //low column start address
  79   2          OLED_WR_Byte(0x10,0);   //high column start address
  80   2          for(n=0;n<128;n++)
  81   2          {
  82   3            OLED_WR_Byte(fill_Data,1);
  83   3          }
  84   2        }
  85   1      }
