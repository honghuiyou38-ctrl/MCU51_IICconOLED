 267          void OLED_Init(void)
 268          {   
 269   1       
 270   1        OLED_WR_Byte(0xAE,OLED_CMD);//--display off
 271   1        OLED_WR_Byte(0x00,OLED_CMD);//---set low column address
 272   1        OLED_WR_Byte(0x10,OLED_CMD);//---set high column address
