 197          void OLED_ShowNum(u8 x,u8 y,u32 num,u8 len,u8 size2)
 198          {           
 199   1        u8 t,temp;
 200   1        u8 enshow=0;               
 201   1        for(t=0;t<len;t++)
 202   1        {
 203   2          temp=(num/oled_pow(10,len-t-1))%10;
 204   2          if(enshow==0&&t<(len-1))
 205   2          {
 206   3            if(temp==0)
 207   3            {
 208   4              OLED_ShowChar(x+(size2/2)*t,y,' ',size2);
 209   4              continue;
 210   4            }
 211   3            else 
 212   3              enshow=1;        
 213   3          }
 214   2          OLED_ShowChar(x+(size2/2)*t,y,temp+'0',size2); 
 215   2        }
 216   1      } 
